# =============================================================
#  Planning Poker — .gitignore
# =============================================================

# ---------------- Python (backend) --------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
MANIFEST
*.sage.py

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# pytest / coverage
.pytest_cache/
.cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
htmlcov/
.coverage
.coverage.*

# mypy / pyright / ruff
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/
.ruff_cache/

# ---------------- Node.js (frontend) ------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm/
.yarn/
.pnp.*
.eslintcache
*.tsbuildinfo

# Vite / build output
frontend/dist/
frontend/dist-ssr/
frontend/.vite/

# Local env files (keep .env.example, ignore real secrets)
frontend/.env
frontend/.env.local
frontend/.env.*.local

# ---------------- Editors / IDEs ----------------------------
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.ipr
*.iws
out/

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace
*.sublime-project

# Vim / Neovim
*.swp
*.swo
*.swn
*~
.netrwhist

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ---------------- OS ----------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump

# Linux
.directory

# ---------------- Misc --------------------------------------
*.log
*.bak
*.tmp
*.temp
.history/
.direnv/
